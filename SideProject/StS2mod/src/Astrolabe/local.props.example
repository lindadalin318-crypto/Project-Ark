<!-- 复制此文件为 local.props，填入你自己的路径（local.props 不提交到 git）-->
<Project>
  <PropertyGroup>
    <!-- STS2 Steam 安装路径 -->
    <STS2GamePath>F:\SteamLibrary\steamapps\common\Slay the Spire 2</STS2GamePath>

    <!-- Godot 4.5.1 Mono 可执行文件完整路径（用于生成 .pck）
         下载地址：https://godotengine.org/download/archive/4.5.1-stable/
         选择 Windows 64-bit .NET 版本 -->
    <GodotExePath>C:\Godot\Godot_v4.5.1-stable_mono_win64.exe</GodotExePath>
  </PropertyGroup>
</Project>
